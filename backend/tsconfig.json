{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "lib": [
      "ES2020"
    ],
    "target": "ES2020",
    "module": "commonjs"
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}